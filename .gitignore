# ===========================================
# Generate_TizenApp .gitignore
# ===========================================

# 다운로드된 NuGet 패키지 (스크립트로 재다운로드 가능)
Packages/

# 생성된 프로젝트 출력 (매번 새로 생성)
output/

# NuGet 실행 파일
nuget.exe

# 빌드 로그
*_log.txt
*_err.txt

# .NET 빌드 산출물
bin/
obj/
*.user
*.suo
*.cache

# OS 파일
Thumbs.db
.DS_Store

# IDE
.vs/
*.swp
*~
